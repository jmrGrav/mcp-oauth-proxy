# MCP OAuth Proxy — Configuration
# Copy this file to /etc/mcp-oauth-proxy/secrets.env and fill in the values.
# Permissions: chmod 600 /etc/mcp-oauth-proxy/secrets.env

# OAuth 2.1 client credentials
# These must match what you register in Claude.ai (or any MCP client)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret_min_32_chars

# Grav MCP plugin bearer token
# Must match the token set in Grav Admin → Plugins → MCP Server
GRAV_TOKEN=your_grav_mcp_bearer_token

# Internal URL of the Grav MCP plugin endpoint (via loopback)
GRAV_MCP_URL=http://127.0.0.1/api/mcp

# Grav site hostname (used as Host header for internal requests)
GRAV_HOST=www.your-domain.com

# Public base URL of this proxy (used in OAuth discovery endpoints)
PROXY_BASE_URL=https://mcp.your-domain.com

# Token storage (JSON file — stores SHA-256 hashes only, never plain tokens)
TOKENS_FILE=/opt/mcp-oauth-proxy/tokens.json

# Audit log file (JSON lines format)
AUDIT_LOG_FILE=/var/log/mcp-oauth/audit.log

# Proxy listen address and port
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8083
